# Security Credentials
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
SMTP_PASSWORD=your_email_password_or_app_password_here

# Face Recognition
# Set to false to disable face identification and face saving entirely (default: true)
FACE_RECOGNITION_ENABLED=true

# Object Detection Backend
# Options: yolo | rf-detr
OBJECT_DETECTOR_BACKEND=yolo
# Used only when OBJECT_DETECTOR_BACKEND=rf-detr
RF_DETR_MODEL_ID=Roboflow/rf-detr-base

# YOLO model files
YOLO_POSE_MODEL=yolo26x-pose.pt
YOLO_OBJ_MODEL=yolo26x.pt
YOLO_SPECIALIZED_MODEL=shoplifting.pt

# Ultralytics Tracking Configuration (Solutions Best Practices)
# Choose tracker: botsort.yaml (more accurate) or bytetrack.yaml (faster)
TRACKER_TYPE=botsort.yaml
# Confidence threshold for object tracking (0.1-1.0)
TRACKER_CONF=0.5
# IoU threshold for non-maximum suppression (0.1-1.0)
TRACKER_IOU=0.5

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Docker Configuration (when running backend in container)
# NEXT_PUBLIC_API_URL=http://backend:8000

# Python Configuration
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
